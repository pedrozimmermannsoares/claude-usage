# ---- profile discovery (no hardcoded paths) --------------------------------
def label_for(config_dir):
    base = os.path.basename(config_dir.rstrip("/"))
    if base == ".claude":
        return "default"
    if base.startswith(".claude-"):
        return base[len(".claude-"):]
    return base.lstrip(".") or base


def discover_profiles():
    """Ordered list of (label, config_dir) found on this machine."""
    found = {}  # config_dir -> label, preserves insertion order

    def add(cdir):
        if not cdir:
            return
        cdir = os.path.abspath(os.path.expanduser(cdir))
        if os.path.isdir(cdir) and cdir not in found:
            found[cdir] = label_for(cdir)

    add(os.environ.get("CLAUDE_CONFIG_DIR"))
    # Named profiles before the bare default: when ~/.claude points at the same
    # account as a ~/.claude-<name> dir, the named one is kept and the default
    # collapses into it (see account dedup below) instead of being queried twice.
    for p in sorted(glob.glob(os.path.join(HOME, ".claude-*"))):
        add(p)
    add(os.path.join(HOME, ".claude"))
    return [(label, cdir) for cdir, label in found.items()]


# ---- credential resolution -------------------------------------------------
def candidate_services(config_dir):
    """Keychain service names to try, in order, for a CLAUDE_CONFIG_DIR.

    Claude Code stores per-config-dir credentials under
    `Claude Code-credentials-<first 8 hex of sha256(path)>`. The exact input is
    not documented, so we try a few normalizations and use whichever exists.
    """
    inputs = []
    for s in (config_dir, config_dir.rstrip("/"), config_dir + "/", os.path.realpath(config_dir)):
        if s not in inputs:
            inputs.append(s)
    names = []
    for s in inputs:
        h = hashlib.sha256(s.encode()).hexdigest()[:8]
        name = "%s-%s" % (KEYCHAIN_PREFIX, h)
        if name not in names:
            names.append(name)
    names.append(KEYCHAIN_PREFIX)  # default profile (no override)
    return names


def read_keychain(service):
    """Return the secret blob (str) from the macOS Keychain, or None.

    The first read of an item may show a GUI authorization prompt; click
    "Always Allow" to avoid being asked again.
    """
    try:
        out = subprocess.run(
            ["security", "find-generic-password", "-s", service, "-w"],
            capture_output=True, text=True, timeout=30,
        )
    except Exception:
        return None
    if out.returncode != 0:
        return None
    return out.stdout.strip() or None


def parse_oauth(blob):
    """Extract the OAuth dict from a JSON blob (with or without a wrapper)."""
    try:
        data = json.loads(blob)
    except Exception:
        return None
    if isinstance(data, dict):
        if isinstance(data.get("claudeAiOauth"), dict):
            return data["claudeAiOauth"]
        if "accessToken" in data or "access_token" in data:
            return data
    return None


def load_credentials(config_dir):
    """Return (oauth_dict, source_str, store) or (None, reason_str, None).

    `store` records where the credential lives ({"kind": "file"|"keychain", ...}
    plus the parsed top-level blob) so a refreshed token can be written back to
    the exact same place — see persist_credentials()."""
    # 1) credentials file (fallback / non-macOS platforms)
    fpath = os.path.join(config_dir, ".credentials.json")
    if os.path.isfile(fpath):
        try:
            with open(fpath) as fh:
                raw = fh.read()
            oauth = parse_oauth(raw)
            if oauth:
                store = {"kind": "file", "path": fpath, "full": json.loads(raw)}
                return oauth, "file %s" % fpath, store
        except Exception:
            pass
    # 2) macOS Keychain (candidate service names)
    for service in candidate_services(config_dir):
        blob = read_keychain(service)
        if not blob:
            continue
        oauth = parse_oauth(blob)
        if oauth:
            store = {"kind": "keychain", "service": service, "full": json.loads(blob)}
            return oauth, "keychain «%s»" % service, store
    return None, "credential not found (Keychain / file)", None


def account_uuid_for(config_dir):
    """Account uuid for a config dir, read LOCALLY from Claude Code's own
    .claude.json (oauthAccount.accountUuid). For the bare ~/.claude the file
    lives NEXT TO the dir (~/.claude.json). Never printed — only used to group
    profiles that belong to the same account."""
    cdir = os.path.abspath(config_dir)
    candidates = [os.path.join(cdir, ".claude.json")]
    if os.path.basename(cdir) == ".claude":
        candidates.append(os.path.join(os.path.dirname(cdir), ".claude.json"))
    for path in candidates:
        try:
            with open(path) as fh:
                obj = json.load(fh)
            uuid = (obj.get("oauthAccount") or {}).get("accountUuid")
            if uuid:
                return str(uuid)
        except Exception:
            continue
    return None


def account_id(oauth):
    """Stable per-account key so the SAME Anthropic account is not queried twice
    when it appears under several config dirs (e.g. ~/.claude and ~/.claude-personal
    sharing one login — the rate limit is per account, so a second call gets 429).

    Best-effort and local-only: decode the JWT access token's subject claim and
    fall back to a hash of the token. The value is used purely for de-duplication;
    it is never printed or sent anywhere.
    """
    tok = oauth.get("accessToken") or oauth.get("access_token") or ""
    if not tok:
        return None
    parts = tok.split(".")
    if len(parts) >= 2:
        try:
            seg = parts[1] + "=" * (-len(parts[1]) % 4)
            claims = json.loads(base64.urlsafe_b64decode(seg).decode("utf-8", "replace"))
            for k in ("sub", "account_uuid", "account_id", "user_id", "uuid", "email"):
                if claims.get(k):
                    return "id:%s" % claims[k]
        except Exception:
            pass
    return "tok:%s" % hashlib.sha256(tok.encode()).hexdigest()[:16]


# ---- token refresh (only when expired; rotated token is saved back) ---------
def token_expired(oauth, skew_ms=60000):
    """True when the access token is past (or within skew_ms of) its expiry.
    Unknown expiry counts as NOT expired — the API call itself will decide."""
    exp = oauth.get("expiresAt") or oauth.get("expires_at")
    if not isinstance(exp, (int, float)):
        return False
    return time.time() * 1000.0 >= float(exp) - skew_ms


def refresh_oauth(oauth):
    """Refresh the access token the same way Claude Code does. Mutates `oauth`
    in place; returns (True, None) or (False, reason).

    Anthropic refresh tokens ROTATE (single-use): the response carries a new
    refresh_token and the old one is invalidated server-side, so the caller MUST
    persist the mutated credential (persist_credentials) or the Claude Code
    login for this profile breaks on its own next refresh."""
    import urllib.request
    import urllib.error

    rtok = oauth.get("refreshToken") or oauth.get("refresh_token")
    if not rtok:
        return False, "access token expired and credential has no refreshToken"
    scopes = oauth.get("scopes")
    scope = " ".join(scopes) if isinstance(scopes, list) and scopes else OAUTH_SCOPES
    payload = json.dumps({
        "grant_type": "refresh_token",
        "refresh_token": rtok,
        "client_id": OAUTH_CLIENT_ID,
        "scope": scope,
    }).encode()
    req = urllib.request.Request(OAUTH_TOKEN_URL, data=payload, method="POST")
    req.add_header("Content-Type", "application/json")
    req.add_header("Accept", "application/json")
    req.add_header("User-Agent", "claude-usage-cli")
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            body = json.loads(resp.read().decode())
    except urllib.error.HTTPError as e:
        if e.code in (400, 401):
            return False, "refresh token rejected (HTTP %d) — run Claude Code in this profile to log in again" % e.code
        return False, "token refresh failed: HTTP %d" % e.code
    except Exception as e:
        return False, "token refresh failed: %s" % e
    tok = body.get("access_token")
    if not tok:
        return False, "token refresh failed: no access_token in response"
    oauth["accessToken"] = tok
    oauth.pop("access_token", None)
    if body.get("refresh_token"):
        oauth["refreshToken"] = body["refresh_token"]
        oauth.pop("refresh_token", None)
    if isinstance(body.get("expires_in"), (int, float)):
        oauth["expiresAt"] = int(time.time() * 1000 + body["expires_in"] * 1000)
    return True, None


def parse_keychain_account(find_output):
    """Pull the account name out of `security find-generic-password` output:
    it appears as "acct"<blob>="name" (or 0x<hex> for non-ASCII names)."""
    m = re.search(r'"acct"<blob>=(?:"((?:[^"\\]|\\.)*)"|0x([0-9A-Fa-f]+))', find_output or "")
    if not m:
        return None
    if m.group(1) is not None:
        return m.group(1)
    try:
        return bytes.fromhex(m.group(2)).decode("utf-8", "replace").rstrip("\x00")
    except Exception:
        return None


def persist_credentials(store, oauth):
    """Write the refreshed credential back to where it was read from, in Claude
    Code's own format. Returns (ok, reason). The JSON MUST be minified: the
    `security` CLI hex-encodes multi-line values, which Claude Code can't read
    back and would treat as an invalid session."""
    if not store:
        return False, "unknown credential source"
    full = store.get("full")
    if isinstance(full, dict) and isinstance(full.get("claudeAiOauth"), dict):
        full = dict(full)
        full["claudeAiOauth"] = oauth
    else:
        full = oauth
    blob = json.dumps(full, separators=(",", ":"))
    if store["kind"] == "file":
        try:
            tmp = store["path"] + ".tmp"
            fd = os.open(tmp, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
            with os.fdopen(fd, "w") as fh:
                fh.write(blob)
            os.replace(tmp, store["path"])
            return True, None
        except Exception as e:
            return False, "could not write %s: %s" % (store["path"], e)
    # keychain: update the SAME item (service + account) Claude Code reads
    try:
        out = subprocess.run(["security", "find-generic-password", "-s", store["service"]],
                             capture_output=True, text=True, timeout=30)
        acct = parse_keychain_account(out.stdout) or os.environ.get("USER") or ""
        upd = subprocess.run(
            ["security", "add-generic-password", "-U", "-a", acct, "-s", store["service"], "-w", blob],
            capture_output=True, text=True, timeout=30)
        if upd.returncode != 0:
            return False, "keychain update failed: %s" % (upd.stderr.strip() or "exit %d" % upd.returncode)
        return True, None
    except Exception as e:
        return False, "keychain update failed: %s" % e


# ---- usage API -------------------------------------------------------------
def api_get(url, access_token):
    """GET an OAuth endpoint. Return (status_int, json_or_text). Stdlib only."""
    import urllib.request
    import urllib.error

    req = urllib.request.Request(url, method="GET")
    req.add_header("Authorization", "Bearer %s" % access_token)
    req.add_header("anthropic-beta", BETA_HEADER)
    req.add_header("Accept", "application/json")
    req.add_header("User-Agent", "claude-usage-cli")
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            body = resp.read().decode()
            try:
                return resp.status, json.loads(body)
            except Exception:
                return resp.status, body
    except urllib.error.HTTPError as e:
        body = e.read().decode(errors="replace")
        try:
            return e.code, json.loads(body)
        except Exception:
            return e.code, body
    except Exception as e:
        return 0, "network error: %s" % e


def fetch_usage(access_token):
    return api_get(USAGE_URL, access_token)


def live_tier(data):
    """Pull organization.rate_limit_tier out of a /profile response, else None."""
    if isinstance(data, dict) and isinstance(data.get("organization"), dict):
        t = data["organization"].get("rate_limit_tier")
        if t:
            return str(t)
    return None


def fetch_profile_tier(access_token):
    """The account's CURRENT rate_limit_tier from the profile endpoint, or None.
    The rateLimitTier stored in the credential goes stale when the subscription
    changes (Claude Code only rewrites it on login), so the live value wins.
    Only the tier string is kept — names/emails in the response are discarded."""
    status, data = api_get(PROFILE_URL, access_token)
    if status == 200:
        return live_tier(data)
    return None


def failure_reason(status, data):
    if status == 0:
        return str(data)
    if status == 401:
        return "token expired/invalid (401) — use Claude in this profile once to refresh"
    if status == 429:
        return "rate limited (429)"
    msg = ""
    if isinstance(data, dict) and isinstance(data.get("error"), dict):
        msg = data["error"].get("message", "")
    return "HTTP %s%s" % (status, (": " + msg) if msg else "")


# ---- local cache (so 429 / outages still show something) -------------------
def cache_dir():
    base = os.environ.get("XDG_CACHE_HOME") or os.path.join(HOME, ".cache")
    return os.path.join(base, "claude-usage")


def cache_file(config_dir):
    h = hashlib.sha256(os.path.abspath(config_dir).encode()).hexdigest()[:16]
    return os.path.join(cache_dir(), h + ".json")


def write_cache(config_dir, data, tier=None):
    try:
        os.makedirs(cache_dir(), exist_ok=True)
        tmp = cache_file(config_dir) + ".tmp"
        with open(tmp, "w") as fh:
            json.dump({"fetched_at": time.time(), "data": data, "tier": tier}, fh)
        os.replace(tmp, cache_file(config_dir))
    except Exception:
        pass  # cache is best-effort


def read_cache(config_dir):
    try:
        with open(cache_file(config_dir)) as fh:
            obj = json.load(fh)
        return obj.get("data"), obj.get("fetched_at"), obj.get("tier")
    except Exception:
        return None, None, None


def fingerprint(data):
    """Account-stable fingerprint built from the windows' reset timestamps
    (microsecond precision → effectively unique per account). Lets us recognize
    two profiles that point at the SAME account even with opaque tokens and no
    account id in the credential. Returns None when there are no windows."""
    if not isinstance(data, dict):
        return None
    stamps = []
    for k in sorted(data.keys()):
        v = data.get(k)
        if isinstance(v, dict):
            r = v.get("resets_at") or v.get("reset_at") or v.get("resetsAt")
            if r:
                stamps.append("%s=%s" % (k, r))
    if not stamps:
        return None
    return hashlib.sha256("|".join(stamps).encode()).hexdigest()[:16]


def _fp_store_path():
    return os.path.join(cache_dir(), "accounts.json")


def load_fp_store():
    try:
        with open(_fp_store_path()) as fh:
            return json.load(fh)
    except Exception:
        return {}


def save_fp(config_dir, fp):
    """Remember which account fingerprint a config dir last produced, so the same
    account can be recognized later even if its token is temporarily rate-limited."""
    try:
        os.makedirs(cache_dir(), exist_ok=True)
        store = load_fp_store()
        store[os.path.abspath(config_dir)] = fp
        tmp = _fp_store_path() + ".tmp"
        with open(tmp, "w") as fh:
            json.dump(store, fh)
        os.replace(tmp, _fp_store_path())
    except Exception:
        pass


# ---- local usage cost (from Claude Code JSONL transcripts) ------------------
# Same approach as ccusage / OpenUsage: parse <config_dir>/projects/**/*.jsonl,
# dedup by message.id + requestId (resumed sessions re-write the same entries),
# and price tokens at API rates. Estimates only — subscriptions aren't billed
# per token. Prices are $/MTok; cache write costs 1.25x input (5m TTL) or
# 2x (1h TTL); cache reads cost 0.1x input.
USAGE_CACHE_VERSION = 1
MODEL_PRICES = [  # first substring match wins — keep specific entries first
    ("fable-5", (10.0, 50.0)),
    ("opus-4-8", (5.0, 25.0)),
    ("opus-4-7", (5.0, 25.0)),
    ("opus-4-6", (5.0, 25.0)),
    ("opus-4-5", (5.0, 25.0)),
    ("opus", (15.0, 75.0)),      # opus 4.1 / 4.0 / 3
    ("sonnet", (3.0, 15.0)),
    ("haiku-4-5", (1.0, 5.0)),
    ("haiku-3-5", (0.8, 4.0)),
    ("haiku", (0.25, 1.25)),
]


def model_price(model):
    m = (model or "").lower()
    for frag, price in MODEL_PRICES:
        if frag in m:
            return price
    return None


def entry_tokens(usage):
    """Total tokens of one assistant message: input + output + cache write/read
    (matches how OpenUsage/ccusage count 'tokens')."""
    total = 0
    for k in ("input_tokens", "output_tokens",
              "cache_creation_input_tokens", "cache_read_input_tokens"):
        v = usage.get(k)
        if isinstance(v, (int, float)) and v > 0:
            total += int(v)
    return total


def entry_cost(model, usage, precomputed=None):
    """USD cost of one assistant message. Prefers the costUSD some Claude Code
    versions precompute; otherwise prices the token counts."""
    if isinstance(precomputed, (int, float)) and precomputed > 0:
        return float(precomputed)
    price = model_price(model)
    if not price:
        return 0.0
    inp, out = price
    cin = float(usage.get("input_tokens") or 0)
    cout = float(usage.get("output_tokens") or 0)
    cread = float(usage.get("cache_read_input_tokens") or 0)
    cc = usage.get("cache_creation") or {}
    cw5 = float(cc.get("ephemeral_5m_input_tokens") or 0)
    cw1 = float(cc.get("ephemeral_1h_input_tokens") or 0)
    if not cw5 and not cw1:
        cw5 = float(usage.get("cache_creation_input_tokens") or 0)
    return (cin * inp + cout * out + cread * inp * 0.1
            + cw5 * inp * 1.25 + cw1 * inp * 2.0) / 1e6


def parse_transcript(path, cutoff_ts):
    """One JSONL transcript -> compact entries [uid16, ts, model, tokens, cost].
    uid is None when message.id/requestId are missing (then it always counts)."""
    out = []
    try:
        with open(path, errors="replace") as fh:
            for line in fh:
                if '"assistant"' not in line or '"usage"' not in line:
                    continue
                try:
                    obj = json.loads(line)
                except Exception:
                    continue
                if obj.get("type") != "assistant":
                    continue
                msg = obj.get("message") or {}
                usage = msg.get("usage")
                if not isinstance(usage, dict):
                    continue
                model = str(msg.get("model") or "")
                if not model or model == "<synthetic>":
                    continue
                try:
                    ts = datetime.fromisoformat(
                        str(obj.get("timestamp")).replace("Z", "+00:00")).timestamp()
                except Exception:
                    continue
                if ts < cutoff_ts:
                    continue
                tokens = entry_tokens(usage)
                if tokens <= 0:
                    continue
                mid, rid = msg.get("id"), obj.get("requestId")
                uid = (hashlib.sha256(("%s:%s" % (mid, rid)).encode()).hexdigest()[:16]
                       if mid and rid else None)
                out.append([uid, ts, model,
                            tokens, round(entry_cost(model, usage, obj.get("costUSD")), 6)])
    except Exception:
        pass
    return out


def usage_cache_file(config_dir):
    h = hashlib.sha256(os.path.abspath(config_dir).encode()).hexdigest()[:16]
    return os.path.join(cache_dir(), "usage-" + h + ".json")


def local_usage(config_dir, days=30):
    """Aggregate the last `days` days of transcript usage for one profile.
    Incremental: per-file entries are cached keyed by (mtime, size); only
    files changed since the previous run are re-parsed."""
    proj = os.path.join(config_dir, "projects")
    if not os.path.isdir(proj):
        return None
    today = datetime.now().date()
    start = datetime.combine(today - timedelta(days=days - 1), datetime.min.time())
    cutoff_ts = start.timestamp()

    try:
        with open(usage_cache_file(config_dir)) as fh:
            cache = json.load(fh)
        if cache.get("version") != USAGE_CACHE_VERSION:
            cache = {}
    except Exception:
        cache = {}
    old_files = cache.get("files") or {}

    files, todo = {}, []
    for root, _dirs, names in os.walk(proj):
        for name in names:
            if not name.endswith(".jsonl"):
                continue
            path = os.path.join(root, name)
            try:
                st = os.stat(path)
            except OSError:
                continue
            if st.st_mtime < cutoff_ts:
                continue  # nothing in range can be inside
            prev = old_files.get(path)
            if prev and prev.get("mtime") == st.st_mtime and prev.get("size") == st.st_size:
                files[path] = prev
            else:
                todo.append((path, st))
    if len(todo) > 50:
        sys.stderr.write("claude-usage: indexing %d transcript files under %s "
                         "(first run can take a while; later runs are incremental)\n"
                         % (len(todo), proj))
    for path, st in todo:
        files[path] = {"mtime": st.st_mtime, "size": st.st_size,
                       "entries": parse_transcript(path, cutoff_ts)}

    try:  # persist; keeping only still-relevant paths prunes stale ones
        os.makedirs(cache_dir(), exist_ok=True)
        tmp = usage_cache_file(config_dir) + ".tmp"
        with open(tmp, "w") as fh:
            json.dump({"version": USAGE_CACHE_VERSION, "files": files}, fh)
        os.replace(tmp, usage_cache_file(config_dir))
    except Exception:
        pass

    seen = set()
    day_tokens, day_cost, model_tokens = {}, {}, {}
    for f in files.values():
        for uid, ts, model, tokens, cost in f["entries"]:
            if ts < cutoff_ts:
                continue
            if uid:
                if uid in seen:
                    continue
                seen.add(uid)
            day = datetime.fromtimestamp(ts).strftime("%Y-%m-%d")
            day_tokens[day] = day_tokens.get(day, 0) + tokens
            day_cost[day] = day_cost.get(day, 0.0) + cost
            model_tokens[model] = model_tokens.get(model, 0) + tokens
    if not day_tokens:
        return None
    return {"day_tokens": day_tokens, "day_cost": day_cost, "model_tokens": model_tokens}


def merge_local(a, b):
    """Merge two local_usage() results (profiles collapsed into one account)."""
    if not b:
        return a
    if not a:
        return {k: dict(v) for k, v in b.items()}
    for k in ("day_tokens", "day_cost", "model_tokens"):
        for kk, vv in b[k].items():
            a[k][kk] = a[k].get(kk, 0) + vv
    return a


# ---- formatting ------------------------------------------------------------
def humanize_reset(iso):
    if not iso:
        return ""
    try:
        dt = datetime.fromisoformat(iso.replace("Z", "+00:00"))
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=timezone.utc)
    except Exception:
        return iso
    secs = int((dt - datetime.now(timezone.utc)).total_seconds())
    if secs <= 0:
        rel = "now"
    elif secs < 3600:
        rel = "in %dm" % (secs // 60)
    elif secs < 86400:
        rel = "in %dh%02dm" % (secs // 3600, (secs % 3600) // 60)
    else:
        rel = "in %dd%dh" % (secs // 86400, (secs % 86400) // 3600)
    return "%s (%s)" % (dt.astimezone().strftime("%d/%m %H:%M"), rel)


def humanize_age(ts):
    if not ts:
        return "unknown age"
    secs = int(time.time() - ts)
    if secs < 60:
        return "%ds ago" % secs
    if secs < 3600:
        return "%dm ago" % (secs // 60)
    if secs < 86400:
        return "%dh%02dm ago" % (secs // 3600, (secs % 3600) // 60)
    return "%dd ago" % (secs // 86400)


def fmt_tokens(n):
    """11_000_000 -> '11M', 6_600_000 -> '6.6M', 1500 -> '1.5K' (OpenUsage style)."""
    n = int(n)
    sign, a = ("-" if n < 0 else ""), abs(n)
    for threshold, divisor, suffix in ((1e9, 1e9, "B"), (1e6, 1e6, "M"), (1e3, 1e3, "K")):
        if a >= threshold:
            scaled = a / divisor
            if scaled >= 10:
                return "%s%d%s" % (sign, round(scaled), suffix)
            txt = "%.1f" % scaled
            if txt.endswith(".0"):
                txt = txt[:-2]
            return sign + txt + suffix
    return "%s%d" % (sign, a)


def percent_label(v):
    """56.123 -> '56.1%', 19.0 -> '19%', 0.05 -> '<0.1%' (OpenUsage style)."""
    if 0 < v < 0.1:
        return "<0.1%"
    r = round(v * 10) / 10.0
    return ("%d%%" % round(r)) if r == int(r) else ("%.1f%%" % r)


def shorten_model(model):
    """'claude-haiku-4-5-20251001' -> 'haiku-4-5' (for compact display)."""
    m = re.sub(r"-\d{8}$", "", model or "")
    return m[7:] if m.startswith("claude-") else m


def sparkline(values):
    """One block char per value, scaled to the max (zero -> baseline ▁)."""
    blocks = "▁▂▃▄▅▆▇█"
    peak = max(values) if values else 0
    if peak <= 0:
        return blocks[0] * len(values)
    return "".join(blocks[0] if v <= 0 else blocks[1 + int(round(6.0 * v / peak))]
                   for v in values)


def bar(remaining, width=20):
    """Bar of what's LEFT: full/green = plenty remaining, empty/red = nearly out."""
    r = max(0.0, min(100.0, float(remaining)))
    fill = int(round(r / 100 * width))
    color = GRN if r > 40 else (YEL if r > 10 else RED)
    return "%s%s%s%s" % (color, "█" * fill, RST, "░" * (width - fill))


def plan_label(oauth, live_tier=None):
    """Return (label, subscriptionType, rateLimitTier). `live_tier` (from the
    profile endpoint) wins over the credential's stored rateLimitTier, which goes
    stale when the subscription changes (Claude Code only rewrites it on login)."""
    sub = str(oauth.get("subscriptionType") or oauth.get("subscription_type") or "?")
    tier = str(live_tier or oauth.get("rateLimitTier") or oauth.get("rate_limit_tier") or "?")
    label = TIER_LABELS.get(tier)
    if not label:
        t = tier.lower()
        if t.endswith("max_20x"):
            label = "Max 20x"
        elif t.endswith("max_5x"):
            label = "Max 5x"
        elif sub in ("pro", "free"):
            label = sub.capitalize()
        else:
            label = sub
    return label, sub, tier


def fmt_window(win):
    """Bar line showing the % that REMAINS, or None if there is no data."""
    util = win.get("utilization")
    if not isinstance(util, (int, float)):
        return None
    remaining = 100.0 - float(util)
    resets = win.get("resets_at") or win.get("reset_at") or win.get("resetsAt")
    return "%s %5.1f%% left  %s%s%s" % (bar(remaining), remaining, DIM, humanize_reset(resets), RST)


def fmt_extra_usage(win):
    """Format the on-demand overage block (NOT the prepaid billing balance).
    used_credits / monthly_limit come from the API in CENTS."""
    if not win.get("is_enabled"):
        return "%sdisabled%s" % (DIM, RST)
    used = float(win.get("used_credits") or 0) / 100.0
    limit = win.get("monthly_limit")
    cur = (win.get("currency") or "").strip()
    lim_s = ("%.2f" % (float(limit) / 100.0)) if isinstance(limit, (int, float)) else "∞"
    util = win.get("utilization")
    pct = "  %s(%.0f%% used)%s" % (DIM, float(util), RST) if isinstance(util, (int, float)) else ""
    return "enabled · %.2f/%s %s%s" % (used, lim_s, cur, pct)


# ---- rendering -------------------------------------------------------------
def render_windows(data, show_all=False):
    W = 14
    shown = set()
    for key, rotulo in WINDOWS:
        win = data.get(key)
        if not isinstance(win, dict):
            continue
        line = fmt_window(win)
        if line is None:
            if not show_all:
                continue
            line = "%s—%s" % (DIM, RST)
        shown.add(key)
        print("   %-*s %s" % (W, rotulo, line))

    eu = data.get("extra_usage")
    if isinstance(eu, dict):
        shown.add("extra_usage")
        print("   %-*s %s" % (W, "overage", fmt_extra_usage(eu)))

    for key in data:
        if key in shown:
            continue
        win = data.get(key)
        if isinstance(win, dict):
            line = fmt_window(win)
            if line is not None:
                shown.add(key)
                print("   %-*s %s" % (W, key, line))

    if show_all:
        rest = [k for k in data if k not in shown]
        if rest:
            print("   %s+ no data: %s%s" % (DIM, ", ".join(rest), RST))


def render_local(loc, days=30):
    """The OpenUsage-style block: cost+tokens today / yesterday / 30d, a daily
    token sparkline, and the per-model token share."""
    W = 14
    day_cost, day_tokens = loc["day_cost"], loc["day_tokens"]
    today = datetime.now().date()
    keys = [(today - timedelta(days=i)).strftime("%Y-%m-%d") for i in range(days - 1, -1, -1)]

    def money_line(cost, tokens):
        return "%s$%.2f%s · %s tokens" % (BOLD, cost, RST, fmt_tokens(tokens))

    print("   %s─ local usage · last %dd · estimated from Claude Code logs at API rates ─%s"
          % (DIM, days, RST))
    print("   %-*s %s" % (W, "today", money_line(day_cost.get(keys[-1], 0.0), day_tokens.get(keys[-1], 0))))
    print("   %-*s %s" % (W, "yesterday", money_line(day_cost.get(keys[-2], 0.0), day_tokens.get(keys[-2], 0))))
    print("   %-*s %s" % (W, "last %dd" % days, money_line(sum(day_cost.values()), sum(day_tokens.values()))))
    tokens_per_day = [day_tokens.get(k, 0) for k in keys]
    print("   %-*s %s%s%s  %speak %s tok/day%s" % (
        W, "trend", YEL, sparkline(tokens_per_day), RST,
        DIM, fmt_tokens(max(tokens_per_day)), RST))
    models = sorted(loc["model_tokens"].items(), key=lambda kv: -kv[1])
    total = sum(t for _m, t in models) or 1
    parts = ["%s %s%s%s" % (shorten_model(m), BOLD, percent_label(100.0 * t / total), RST)
             for m, t in models[:6]]
    if len(models) > 6:
        parts.append("%s+%d more%s" % (DIM, len(models) - 6, RST))
    print("   %-*s %s" % (W, "models", (" %s·%s " % (DIM, RST)).join(parts)))


def gather(label, config_dir, allow_refresh=True, allow_local=True):
    """Fetch one profile's usage (live, falling back to cache) and tag it with the
    account fingerprint. Returns a result dict consumed by the grouping step."""
    res = {"label": label, "config_dir": config_dir, "oauth": None,
           "source": None, "data": None, "stale_age": None, "reason": None, "fp": None,
           "refreshed": False, "persist_warn": None, "tier": None, "local": None,
           "account": account_uuid_for(config_dir)}
    if allow_local:
        res["local"] = local_usage(config_dir)
    oauth, source, store = load_credentials(config_dir)
    res["source"] = source
    if not oauth:
        res["reason"] = source
        return res
    res["oauth"] = oauth

    def do_refresh():
        ok, why = refresh_oauth(oauth)
        if not ok:
            return why
        res["refreshed"] = True
        saved, err = persist_credentials(store, oauth)
        if not saved:
            res["persist_warn"] = err
        return None

    refresh_err = None
    if allow_refresh and token_expired(oauth):
        refresh_err = do_refresh()

    token = oauth.get("accessToken") or oauth.get("access_token")
    if not token:
        res["reason"] = "no accessToken in credential"
        return res

    status, data = fetch_usage(token)
    if status == 401 and allow_refresh and not res["refreshed"] and refresh_err is None:
        refresh_err = do_refresh()
        if refresh_err is None:
            status, data = fetch_usage(oauth.get("accessToken"))
    tier = fetch_profile_tier(oauth.get("accessToken") or oauth.get("access_token"))
    if status == 200 and isinstance(data, dict):
        write_cache(config_dir, data, tier)
        res["data"] = data
    else:
        res["reason"] = refresh_err or failure_reason(status, data)
        cached, ts, cached_tier = read_cache(config_dir)
        if cached is not None:
            res["data"], res["stale_age"] = cached, ts
            tier = tier or cached_tier
    res["tier"] = tier

    fp = fingerprint(res["data"])
    if fp:
        res["fp"] = fp
        save_fp(config_dir, fp)          # learn this account's fingerprint
    else:
        res["fp"] = load_fp_store().get(os.path.abspath(config_dir))  # last known
    return res


def group_key(res):
    """Key that groups profiles belonging to the same account. Prefer the LOCAL
    account uuid from .claude.json (exact, no network); then the usage
    fingerprint (matches across different tokens of one account); then the
    token hash (matches byte-identical/copied logins); else the dir."""
    if res.get("account"):
        return "acct:" + res["account"]
    if res.get("fp"):
        return "fp:" + res["fp"]
    oauth = res.get("oauth") or {}
    tok = oauth.get("accessToken") or oauth.get("access_token")
    if tok:
        return "tok:" + hashlib.sha256(tok.encode()).hexdigest()[:16]
    return "cfg:" + os.path.abspath(res["config_dir"])


def render_group(members, raw=False, show_all=False):
    """Render one account. members[0] is the highest-priority profile (named path
    beats the bare default); data comes from whichever member actually has it."""
    top = members[0]
    data_member = next((m for m in members if m.get("data") is not None), None)
    oauth = top.get("oauth") or (data_member.get("oauth") if data_member else None)

    print("%s%s● %s%s  %s(%s)%s" % (BOLD, CYN, top["label"], RST, DIM, top["config_dir"], RST))
    if oauth is None:
        print("   %s%s%s\n" % (RED, top.get("reason") or "credential not found", RST))
        return
    known_tier = next((m.get("tier") for m in members if m.get("tier")), None)
    plan, sub, tier = plan_label(oauth, known_tier)
    print("   plan:   %s%s%s  %s(%s · rateLimitTier=%s)%s" % (BOLD, plan, RST, DIM, sub, tier, RST))
    stored_tier = oauth.get("rateLimitTier") or oauth.get("rate_limit_tier")
    if known_tier and stored_tier and known_tier != stored_tier:
        print("   %s↳ credential still says %s — stale; live tier from the profile API%s" % (DIM, stored_tier, RST))
    print("   %ssource: %s%s" % (DIM, top.get("source"), RST))

    if len(members) > 1:
        others = ", ".join(m["label"] for m in members[1:])
        print("   %s↳ same account as: %s (collapsed)%s" % (DIM, others, RST))

    if data_member is None:
        print("   %sAPI failure: %s (no cache yet)%s\n" % (RED, top.get("reason") or "no data", RST))
        return
    if data_member is not top:
        print("   %s↳ data via «%s» — «%s» token unavailable (%s)%s" % (
            YEL, data_member["label"], top["label"], top.get("reason"), RST))
    for m in members:
        if m.get("refreshed"):
            print("   %s↻ OAuth token refreshed (rotated token saved back)%s" % (DIM, RST))
        if m.get("persist_warn"):
            print("   %s⚠ refreshed token NOT saved back (%s) — Claude Code may ask to log in again in this profile%s" % (
                RED, m["persist_warn"], RST))
    if data_member.get("stale_age") is not None:
        print("   %s⏁ cached %s — %s%s" % (
            YEL, humanize_age(data_member["stale_age"]),
            data_member.get("reason") or "live fetch failed", RST))

    if raw:
        print(json.dumps(data_member["data"], indent=2, ensure_ascii=False))
        print()
        return
    render_windows(data_member["data"], show_all)
    loc = None
    for m in members:
        loc = merge_local(loc, m.get("local"))
    if loc:
        render_local(loc)
    print()


def open_url(url):
    try:
        if sys.platform == "darwin":
            subprocess.run(["open", url])
        elif sys.platform.startswith("win"):
            os.startfile(url)  # noqa
        else:
            subprocess.run(["xdg-open", url])
        return True
    except Exception:
        return False


def debug_accounts(chosen):
    """Print how each profile maps to an account, WITHOUT exposing any secret:
    only field/claim names and short sha256 hashes of their values. Used to find
    which field uniquely identifies an account so duplicates can be de-duplicated.
    """
    def sha8(v):
        return hashlib.sha256(str(v).encode()).hexdigest()[:8]

    print("debug-accounts (names + hashed values only; no tokens, no raw values)\n")
    for label, cdir in chosen:
        print("● %s  (%s)" % (label, cdir))
        oauth, source, _store = load_credentials(cdir)
        if not oauth:
            print("   %s\n" % source)
            continue
        print("   source: %s" % source)
        print("   cred keys: %s" % ", ".join(sorted(oauth.keys())))
        for k in sorted(oauth.keys()):
            if k in ("accessToken", "access_token", "refreshToken", "refresh_token", "scopes", "expiresAt"):
                continue
            print("     %-18s = #%s" % (k, sha8(oauth[k])))
        tok = oauth.get("accessToken") or oauth.get("access_token") or ""
        parts = tok.split(".")
        print("   token: %d parts (%s)" % (len(parts), "JWT-shaped" if len(parts) >= 3 else "opaque"))
        if len(parts) >= 2:
            try:
                seg = parts[1] + "=" * (-len(parts[1]) % 4)
                claims = json.loads(base64.urlsafe_b64decode(seg).decode("utf-8", "replace"))
                print("   claim keys: %s" % ", ".join(sorted(claims.keys())))
                for k in sorted(claims.keys()):
                    if k in ("exp", "iat", "nbf", "jti"):  # volatile per-token; skip
                        continue
                    print("     %-18s = #%s" % (k, sha8(claims[k])))
            except Exception as e:
                print("   (claim decode failed: %s)" % e)
        print("   account_id() -> #%s" % sha8(account_id(oauth)))
        print()
    print("Compare the hashes: a field whose #value is the SAME for two profiles")
    print("but DIFFERENT for the others identifies the shared account.")


# ---- selftest (no Keychain / no network / no personal data) ----------------
def selftest():
    ok = True

    def check(name, cond):
        nonlocal ok
        ok = ok and bool(cond)
        print("  [%s] %s" % ("OK" if cond else "FAIL", name))

    cands = candidate_services("/tmp/example-config")
    check("service name = prefix + 8 hex",
          any(re.match(r"^Claude Code-credentials-[0-9a-f]{8}$", c) for c in cands))
    check("default (plain) service present", KEYCHAIN_PREFIX in cands)

    check("plan Max 20x", plan_label({"rateLimitTier": "default_claude_max_20x"})[0] == "Max 20x")
    check("plan Max 5x", plan_label({"rateLimitTier": "default_claude_max_5x"})[0] == "Max 5x")
    check("plan Pro", plan_label({"subscriptionType": "pro", "rateLimitTier": "default_claude_ai"})[0] == "Pro")
    check("plan unknown tier falls back to sub", plan_label({"subscriptionType": "team"})[0] == "team")
    check("plan live tier beats stale credential",
          plan_label({"rateLimitTier": "default_claude_max_5x"}, "default_claude_max_20x")[0] == "Max 20x")
    check("plan no live tier -> stored", plan_label({"rateLimitTier": "default_claude_max_5x"}, None)[0] == "Max 5x")
    check("live_tier extracts org tier",
          live_tier({"organization": {"rate_limit_tier": "default_claude_max_20x"}}) == "default_claude_max_20x")
    check("live_tier none on junk", live_tier({"organization": {}}) is None and live_tier("x") is None)

    check("parse_oauth wrapper", (parse_oauth('{"claudeAiOauth":{"accessToken":"x"}}') or {}).get("accessToken") == "x")
    check("parse_oauth flat", (parse_oauth('{"access_token":"y"}') or {}).get("access_token") == "y")
    check("parse_oauth junk -> None", parse_oauth("not json") is None)

    check("fmt_window null -> None", fmt_window({"utilization": None}) is None)
    check("fmt_window numeric -> str", isinstance(fmt_window({"utilization": 42.0, "resets_at": "2030-01-01T00:00:00Z"}), str))
    check("fmt_extra_usage disabled", "disabled" in fmt_extra_usage({"is_enabled": False}))
    check("fmt_extra_usage enabled",
